# ═══ TRUVA Environment Variables ═══

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana RPC (optional — defaults to devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# API Authentication (required in production)
TRUVA_API_KEY=your-secret-api-key

# Reputation Engine URL (for backfill triggers after registration)
REPUTATION_ENGINE_URL=http://localhost:3001
