{
  "name": "@truva/reputation-engine",
  "version": "0.1.0",
  "description": "Truva Protocol — Off-chain reputation engine with Helius webhooks, PostgreSQL, Redis, and on-chain tier writer",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:migrate": "node dist/db/migrate.js && node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:migrate:status": "ts-node src/db/migrate.ts status",
    "test": "node --require ts-node/register --test src/__tests__/*.test.ts",
    "test:scorer": "node --require ts-node/register --test src/__tests__/scorer.test.ts",
    "seed": "ts-node ../../scripts/seedAgents.ts",
    "simulate": "ts-node ../../scripts/simulateTransactions.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "@solana/web3.js": "^1.95.3",
    "@coral-xyz/anchor": "^0.30.1",
    "bs58": "^5.0.0",
    "zod": "^3.23.8",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.11.6",
    "@types/node": "^20.14.0",
    "@types/helmet": "^0.0.48",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.6.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.4"
  }
}
