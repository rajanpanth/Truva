{
  "name": "truva",
  "version": "0.1.0",
  "description": "Truva Protocol — Trust and reputation layer for AI agents on Solana",
  "private": true,
  "scripts": {
    "build:program": "anchor build",
    "test:program": "anchor test",
    "test": "anchor test",
    "seed": "npx ts-node scripts/seedAgents.ts",
    "simulate": "npx ts-node scripts/simulateTransactions.ts",
    "dev:app": "cd app && npm run dev",
    "build:app": "cd app && npm run build",
    "dev:backend": "cd backend/reputation-engine && npm run dev",
    "build:backend": "cd backend/reputation-engine && npm run build",
    "start:backend": "cd backend/reputation-engine && npm run start",
    "db:migrate": "cd backend/reputation-engine && npm run db:migrate"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.3",
    "@solana/spl-token": "^0.4.8"
  },
  "devDependencies": {
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "chai": "^4.5.0",
    "mocha": "^10.7.3",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
