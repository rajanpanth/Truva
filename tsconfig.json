{
  "compilerOptions": {
    "lib": ["es2020"],
    "module": "node16",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "scripts/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "sdk",
    "backend",
    "tests"
  ]
}
